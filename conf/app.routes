# microservice specific routes

POST       /callback                uk.gov.hmrc.eacdfileprocessor.controllers.CallbackController.callback
POST       /initiate                uk.gov.hmrc.eacdfileprocessor.controllers.InitiateFileStorageController.initiateFileRecordStore()
PUT        /status/:reference       uk.gov.hmrc.eacdfileprocessor.controllers.StatusController.updateStatus(reference: String)

GET        /file/:status            uk.gov.hmrc.eacdfileprocessor.controllers.StatusController.getFileStatus(status: String)
